{
  "name": "reindexly",
  "version": "1.0.6",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "mocha",
    "lint": "eslint src test --max-warnings 0",
    "lint:fix": "eslint src test --fix",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "npm run build && npm run typecheck:consumer && npm run typecheck:tests",
    "typecheck:consumer": "tsc test/types/consumer.ts --noEmit --strict --module commonjs --moduleResolution node10 --esModuleInterop --skipLibCheck --ignoreDeprecations 6.0 --ignoreConfig",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "reindex",
    "reindexing",
    "zero-downtime",
    "opensearch",
    "elasticsearch",
    "alias",
    "alias-swap",
    "index-migration",
    "mapping-migration",
    "search-index",
    "online-reindex",
    "resumable",
    "idempotent",
    "state-machine"
  ],
  "author": "Andrii Varlamov",
  "license": "ISC",
  "description": "Resumable, idempotent zero-downtime reindexing for OpenSearch and Elasticsearch",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.1.1",
    "@types/sinon": "^22.0.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "mocha": "^11.7.6",
    "sinon": "^22.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/drummer1992/reindexly"
  }
}
