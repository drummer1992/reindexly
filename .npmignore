# NOTE: package.json "files" (["dist"]) is the allowlist that decides
# what ships. This file mainly exists so npm does NOT fall back to .gitignore
# (which excludes the generated dist/ that we DO want to publish).
#
# Do not add `dist/` here.

# Source and tests
src/
test/

# Build config
tsconfig*.json

# Editor / OS
.idea/
.vscode/
.DS_Store

# Source control / pack artifacts
.gitignore
*.tgz